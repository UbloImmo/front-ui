{
  "name": "@ubloimmo/uikit",
  "description": "Colors, themes, typography, common components for use in frontend applications",
  "version": "0.33.9",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes.js",
      "default": "./dist/themes.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts.js",
      "default": "./dist/layouts.js"
    },
    "./fonts": {
      "types": "./dist/typography/fonts/index.d.ts",
      "import": "./dist/fonts.js",
      "default": "./dist/fonts.js"
    },
    "./sizes": {
      "types": "./dist/sizes/index.d.ts",
      "import": "./dist/sizes.js",
      "default": "./dist/sizes.js"
    }
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Jean-Nicolas Veigel <art.jnveigel@gmail.com>",
  "homepage": "https://github.com/UbloImmo/front-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/UbloImmo/front-ui"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^13.10.1",
    "@rollup/plugin-dynamic-import-vars": "^2.1.2",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-interactions": "^8.2.9",
    "@storybook/addon-links": "^8.2.9",
    "@storybook/addon-measure": "^8.2.9",
    "@storybook/addon-outline": "^8.2.9",
    "@storybook/addon-themes": "^8.2.9",
    "@storybook/addon-viewport": "^8.2.9",
    "@storybook/addon-docs": "^8.2.9",
    "@storybook/blocks": "^8.2.9",
    "@storybook/builder-vite": "8.2.9",
    "@storybook/icons": "^1.2.10",
    "@storybook/react": "^8.2.9",
    "@storybook/react-vite": "^8.2.9",
    "@storybook/test": "^8.2.9",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/bun": "latest",
    "@types/lodash": "^4.17.7",
    "@types/react": "^18.3.5",
    "@types/svg-parser": "^2.0.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-local-rules": "^1.3.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-watch": "^8.0.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "prettier": "^2.8.8",
    "react-docgen-typescript": "^2.2.2",
    "storybook": "^8.2.9",
    "svg-parser": "^2.0.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-banner": "^0.7.1",
    "vite-plugin-dts": "^3.9.1",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ubloimmo/front-tokens": "^0.1.24",
    "@ubloimmo/front-util": "^0.0.17",
    "bootstrap-icons": "^1.11.3",
    "date-fns": "^3.6.0",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-international-phone": "^4.2.9",
    "styled-components": "^6.1.11",
    "typescript": "^5.3.3",
    "uuid": "^10.0.0",
    "vite": "^5.1.6",
    "zod": "^3.23.8"
  },
  "scripts": {
    "incrementRevision": "bun src/scripts/incrementRevision.ts",
    "test:types": "tsc --noEmit",
    "test:types:watch": "tsc --noEmit --watch",
    "test:lint": "eslint . --cache --cache-location .cache/eslint",
    "test:lint:fix": "eslint . --cache --cache-location .cache/eslint --fix",
    "test:unit": "bun test",
    "test:unit:coverage": "bun test --coverage",
    "test:unit:coverage:watch": "bun test --coverage --watch",
    "test:unit:watch": "bun test --watch",
    "test:deps": "bun madge src --extensions js,jsx,ts,tsx",
    "test:deps:circular": "bun madge src --extensions js,jsx,ts,tsx --circular --warning --ts-config tsconfig.json",
    "test:all": "bun test:lint && bun test:types && bun test:deps:circular && bun test:unit",
    "prepare": "husky",
    "pre-push": "bun test:all",
    "icons:generate": "bun scripts/svg/index.ts && bun test:lint:fix",
    "prepublishOnly": "bun lib:build",
    "uninstall": "rm -rf node_modules",
    "reinstall": "bun run uninstall && bun install",
    "storybook": "storybook dev -p 6007 --debug --no-open",
    "storybook:open": "storybook dev -p 6007 --debug",
    "storybook:reinstall": "bun run reinstall && bun storybook",
    "storybook:build": "storybook build",
    "lib:build": "vite build --config vite.config.build.ts",
    "init:component": "./scripts/init/component.sh"
  },
  "type": "module",
  "jest": {
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "html"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.1",
    "@ubloimmo/front-tokens": "^0.1.25",
    "@ubloimmo/front-util": "^0.0.17",
    "date-fns": "^3.6.0",
    "lodash": "^4.17.21",
    "react-day-picker": "^9.0.9",
    "react-international-phone": "^4.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  }
}
