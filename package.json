{
  "name": "@ubloimmo/uikit",
  "description": "Colors, themes, typography, common components for use in frontend applications",
  "version": "1.7.8",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes.js",
      "default": "./dist/themes.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components.js",
      "default": "./dist/components.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts.js",
      "default": "./dist/layouts.js"
    },
    "./fonts": {
      "types": "./dist/typography/fonts/index.d.ts",
      "import": "./dist/fonts.js",
      "default": "./dist/fonts.js"
    },
    "./sizes": {
      "types": "./dist/sizes/index.d.ts",
      "import": "./dist/sizes.js",
      "default": "./dist/sizes.js"
    }
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Jean-Nicolas Veigel <art.jnveigel@gmail.com>",
  "homepage": "https://github.com/UbloImmo/front-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/UbloImmo/front-ui"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.19.0",
    "@happy-dom/global-registrator": "^13.10.1",
    "@storybook/addon-docs": "^8.4.5",
    "@storybook/addon-essentials": "^8.4.5",
    "@storybook/addon-interactions": "^8.4.5",
    "@storybook/addon-links": "^8.4.5",
    "@storybook/addon-measure": "^8.4.5",
    "@storybook/addon-outline": "^8.4.5",
    "@storybook/addon-themes": "^8.4.5",
    "@storybook/addon-viewport": "^8.4.5",
    "@storybook/blocks": "^8.4.5",
    "@storybook/icons": "^1.2.10",
    "@storybook/manager-api": "^8.4.5",
    "@storybook/react": "^8.4.5",
    "@storybook/react-vite": "^8.4.5",
    "@storybook/test": "^8.4.5",
    "@storybook/theming": "^8.4.5",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/big.js": "^6.2.2",
    "@types/bun": "1.2.0",
    "@types/lodash": "^4.17.7",
    "@types/react": "^18.3.5",
    "@types/svg-parser": "^2.0.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@typescript-eslint/typescript-estree": "^8.21.0",
    "bun-types": "latest",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^0.11.2",
    "globals": "^15.14.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "prettier": "^3.4.2",
    "react-docgen-typescript": "^2.2.2",
    "storybook": "^8.4.5",
    "svg-parser": "^2.0.4",
    "typedoc": "^0.27.6",
    "typedoc-plugin-markdown": "^4.4.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-banner": "^0.7.1",
    "vite-plugin-dts": "^3.9.1",
    "vite-plugin-dynamic-import": "^1.6.0",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ubloimmo/front-tokens": "^0.1.34",
    "@ubloimmo/front-util": "^0.0.18",
    "bootstrap-icons": "^1.11.3",
    "date-fns": "^3.6.0",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-international-phone": "^4.2.9",
    "styled-components": "^6.1.11",
    "typescript": "^5.5.4",
    "uuid": "^10.0.0",
    "vite": "^5.1.6",
    "zod": "^3.23.8"
  },
  "scripts": {
    "incrementRevision": "bun src/scripts/incrementRevision.ts",
    "test:types": "tsc --noEmit",
    "test:types:watch": "tsc --noEmit --watch",
    "test:lint": "bun eslint . --cache --cache-location .cache/eslint",
    "test:lint:fix": "bun eslint . --cache --cache-location .cache/eslint --fix",
    "test:lint:debug": "bun eslint . --cache --cache-location .cache/eslint --debug",
    "test:lint:fix:debug": "bun eslint . --cache --cache-location .cache/eslint --fix --debug",
    "test:unit": "bun test",
    "test:unit:coverage": "bun test --coverage",
    "test:unit:coverage:watch": "bun test --coverage --watch",
    "test:unit:watch": "bun test --watch",
    "test:deps": "bun madge src --extensions js,jsx,ts,tsx",
    "test:deps:circular": "bun madge src --extensions js,jsx,ts,tsx --circular --warning --ts-config tsconfig.json",
    "test:all": "bun test:lint && bun test:types && bun test:deps:circular && bun test:unit",
    "prepare": "husky",
    "pre-push": "./scripts/pre-push.sh || bun test:all",
    "icons:generate": "bun scripts/svg/index.ts && bun test:lint:fix",
    "prepublishOnly": "bun lib:build",
    "uninstall": "rm -rf node_modules",
    "reinstall": "bun run uninstall && bun install",
    "storybook": "storybook dev -p 6007 --debug --no-open",
    "storybook:open": "storybook dev -p 6007 --debug",
    "storybook:reinstall": "bun run reinstall && bun storybook",
    "storybook:build": "storybook build",
    "lib:build": "vite build --config vite.config.build.ts",
    "init:component": "./scripts/init/component.sh",
    "docs:generate": "bunx typedoc --options ./typedoc.config.js",
    "changelog:added": "./scripts/ci/add-to-changelog.sh \"Added\" ",
    "changelog:changed": "./scripts/ci/add-to-changelog.sh \"Changed\" ",
    "changelog:deprecated": "./scripts/ci/add-to-changelog.sh \"Deprecated\" ",
    "changelog:removed": "./scripts/ci/add-to-changelog.sh \"Removed\" ",
    "changelog:fixed": "./scripts/ci/add-to-changelog.sh \"Fixed\" ",
    "changelog:security": "./scripts/ci/add-to-changelog.sh \"Security\" "
  },
  "type": "module",
  "jest": {
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "html"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.1",
    "@ubloimmo/front-tokens": "^0.1.38",
    "@ubloimmo/front-util": "^0.0.18",
    "big.js": "^6.2.2",
    "date-fns": "^3.6.0",
    "lodash": "^4.17.21",
    "react-day-picker": "^9.0.9",
    "react-international-phone": "^4.2.9",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  }
}
