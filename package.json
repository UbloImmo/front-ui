{
  "name": "@ubloimmo/front-ui",
  "description": "Colors, themes, typography, common components for use in frontend applications",
  "version": "0.0.1",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "files": [
    "src"
  ],
  "license": "MIT",
  "author": "Jean-Nicolas Veigel <art.jnveigel@gmail.com>",
  "homepage": "https://github.com/UbloImmo/front-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/UbloImmo/front-ui"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^13.3.1",
    "@storybook/addon-essentials": "^8.0.4",
    "@storybook/addon-interactions": "^8.0.4",
    "@storybook/addon-links": "^8.0.4",
    "@storybook/addon-measure": "^8.0.4",
    "@storybook/addon-outline": "^8.0.4",
    "@storybook/addon-themes": "^8.0.4",
    "@storybook/addon-viewport": "^8.0.4",
    "@storybook/blocks": "^8.0.4",
    "@storybook/builder-vite": "^8.0.4",
    "@storybook/icons": "^1.2.9",
    "@storybook/react": "^8.0.4",
    "@storybook/react-vite": "^8.0.4",
    "@storybook/test": "^8.0.4",
    "@testing-library/react": "^14.1.2",
    "@types/bun": "latest",
    "@types/react": "^18.2.48",
    "@types/svg-parser": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "bun-types": "latest",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-local-rules": "^1.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-watch": "^8.0.0",
    "jest": "^29.7.0",
    "madge": "^6.1.0",
    "prettier": "^2.8.7",
    "react-dom": "^18.2.0",
    "storybook": "^8.0.4",
    "svg-parser": "^2.0.4",
    "typescript": "^5.3.3",
    "vite": "^5.1.6",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "peerDependencies": {
    "typescript": "^5.3.3",
    "vite": "^5.1.6"
  },
  "scripts": {
    "incrementRevision": "bun src/scripts/incrementRevision.ts",
    "test:types": "tsc --noEmit",
    "test:types:watch": "tsc --noEmit --watch",
    "test:lint": "eslint . --cache --cache-location .cache/eslint",
    "test:lint:fix": "eslint . --cache --cache-location .cache/eslint --fix",
    "test:unit": "bun test",
    "test:unit:coverage": "bun test --coverage",
    "test:unit:coverage:watch": "bun test --coverage --watch",
    "test:unit:watch": "bun test --watch",
    "test:deps": "bun madge src --extensions js,jsx,ts,tsx",
    "test:deps:circular": "bun madge src --extensions js,jsx,ts,tsx --circular",
    "test:all": "bun test:lint && bun test:types && bun test:deps:circular && bun test:unit",
    "prepare": "husky",
    "pre-push": "bun test:all",
    "pre-commit": "bun test:unit",
    "icons:generate": "bun scripts/svg/index.ts",
    "storybook": "storybook dev -p 6007 --debug",
    "build-storybook": "storybook build"
  },
  "type": "module",
  "dependencies": {
    "@fontsource-variable/open-sans": "^5.0.23",
    "@ubloimmo/front-tokens": "^0.1.8",
    "@ubloimmo/front-util": "latest",
    "bootstrap-icons": "^1.11.3",
    "husky": "^9.0.10",
    "react": "^18.2.0",
    "react-bootstrap-icons": "^1.10.3",
    "styled-components": "^6.1.8"
  },
  "jest": {
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "html"
    ]
  }
}
