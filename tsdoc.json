{
  "$schema": "https://developer.microsoft.com/json-schemas/tsdoc/v0/tsdoc.schema.json",
  "extends": [
    "@microsoft/api-extractor/extends/tsdoc-base.json",
    "typedoc/tsdoc.json"
  ],
  "noStandardTags": false,
  "tagDefinitions": [
    {
      "tagName": "@version",
      "syntaxKind": "block"
    },
    {
      "tagName": "@required",
      "syntaxKind": "modifier"
    },
    {
      "tagName": "@todo",
      "syntaxKind": "block"
    },
    {
      "tagName": "@type",
      "syntaxKind": "block"
    },
    {
      "tagName": "@default",
      "syntaxKind": "block"
    }
  ]
}
